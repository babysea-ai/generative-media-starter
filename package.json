{
  "name": "generative-media-starter",
  "version": "0.2.5",
  "description": "Credit-based generative media app. Built with Next.js, Stripe, Supabase, Upstash, and the BabySea SDK.",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://demo.generative-media-starter.babysea.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-ai/generative-media-starter.git"
  },
  "keywords": [
    "babysea",
    "open-source",
    "starter-pack",
    "stripe",
    "supabase",
    "upstash",
    "vercel",
    "ai-infrastructure",
    "control-plane",
    "execution-layer",
    "developer-tools",
    "generative-ai",
    "inference-providers",
    "image-generation",
    "video-generation",
    "multimodal",
    "generative-media",
    "creative-tools"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "next dev --port=3011",
    "doctor": "node scripts/doctor.mjs",
    "sentry:check": "node scripts/sentry-project-check.mjs",
    "format": "prettier --check \"**/*.{ts,tsx,css,md,json,mjs}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,css,md,json,mjs}\"",
    "start": "next start",
    "supabase": "supabase",
    "supabase:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "supabase:push": "supabase db push",
    "supabase:typegen": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > ./lib/database.types.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@upstash/ratelimit": "catalog:",
    "@upstash/redis": "catalog:",
    "babysea": "catalog:",
    "clsx": "catalog:",
    "ignore": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "stripe": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "prettier": "catalog:",
    "supabase": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.19.0"
}
