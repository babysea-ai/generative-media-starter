# App
# Local development: http://localhost:3011
# Production: https://your-app.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3011

# BabySea
# Required server-only key. Never expose this with NEXT_PUBLIC_.
BABYSEA_API_KEY=

# Optional. Defaults to https://api.us.babysea.ai.
BABYSEA_API_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional direct Price ID overrides. If unset, the app resolves Prices by
# lookup key from lib/app-config.ts.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_PRODUCTION=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET_KEY=

# Supabase CLI only. Not required at runtime.
SUPABASE_PROJECT_REF=

# Upstash
# Required in production. Optional only for local development.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
